# ============================================================
# FinFlow Pro — Backend Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to version control
# ============================================================

# ─── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# ─── MongoDB Atlas ───────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/finflow_pro?retryWrites=true&w=majority
MONGODB_DB_NAME=finflow_pro

# ─── JWT Authentication ─────────────────────────────────────
JWT_ACCESS_SECRET=your_access_token_secret_min_64_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_min_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# ─── Redis (Upstash) ────────────────────────────────────────
REDIS_HOST=your-redis-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_TLS=true

# ─── BullMQ Queue ────────────────────────────────────────────
BULL_QUEUE_PREFIX=finflow

# ─── Cloudinary (PDF Receipt Storage) ───────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=finflow-receipts

# ─── Twilio (SMS + WhatsApp) ────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_SMS_FROM=+1234567890
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Telegram Bot ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/v1/integrations/telegram/webhook
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id

# ─── Puppeteer (PDF Generation) ─────────────────────────────
PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_HEADLESS=true

# ─── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=10

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ─── Encryption (AES-256 for sensitive fields) ──────────────
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FILE_PATH=./logs

# ─── Business Defaults ──────────────────────────────────────
DEFAULT_FEE_PERCENT=1.5
DEFAULT_COMMISSION_PERCENT=0.5
DEFAULT_CURRENCY=BDT
DEFAULT_CURRENCY_SYMBOL=৳
